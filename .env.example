# Database connection string (SQLAlchemy URL format)
# Dev:  sqlite:///./siem.db
# Prod: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./siem.db

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application identity (used in logs and the /health response)
APP_NAME=siem-log-analyzer
APP_ENV=development

# Require a complete, integrity-verified model release at startup.
# Keep false locally (a fresh clone has no model); set true in production
# (render.yaml sets it) so a missing model is a hard startup failure, not a
# silent "AI SIEM" with no model.
MODEL_REQUIRED=false

# --- Docker Compose only (optional) ---
# docker-compose.yml reads these to build the Postgres container and the
# app's DATABASE_URL. All have defaults baked into the compose file
# (user/db "siem", password "siem_local_only"), so you only need to set
# them to override — e.g. a different local password. NOT used when
# running the app directly.
# POSTGRES_USER=siem
# POSTGRES_PASSWORD=siem_local_only
# POSTGRES_DB=siem