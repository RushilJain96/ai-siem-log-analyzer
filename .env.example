# Database connection string (SQLAlchemy URL format)
# Dev:  sqlite:///./siem.db
# Prod: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./siem.db

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application identity (used in logs and the /health response)
APP_NAME=siem-log-analyzer
APP_ENV=development