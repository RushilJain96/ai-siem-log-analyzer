# === Dataset and model artifacts ===
# CICIDS CSVs are gigabytes; never committed

data/raw/*
!data/raw/.gitkeep

# Trained sklearn/joblib model files — ignored by default...
*.pkl
*.joblib

# ...EXCEPT the two approved, deployed artifacts. These (plus their
# model/model_card.json release record) are committed so the deployed
# service ships with an integrity-verified model. Any other .pkl anywhere
# stays out. See model/artifact_integrity.py.
!model/preprocessor.pkl
!model/isolation_forest.pkl

# === Python runtime ===

__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/

# === Virtual environments ===

.venv/
venv/
env/

# === Secrets and environment config ===
# Real secrets — never committed
.env
.env.*

# Template — IS committed, hence the negation
!.env.example

# === Local databases ===
*.db
*.sqlite
*.sqlite3

# === Testing and linting caches ===
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# === Notebook checkpoints ===
.ipynb_checkpoints/

# === Application logs ===
*.log
logs/

# === IDE and editor ===
.vscode/
.idea/
*.swp

# === OS junk ===
.DS_Store
Thumbs.db