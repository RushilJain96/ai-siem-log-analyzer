# Keep the build context small and keep secrets/artifacts out of the image.
# The Dockerfile does `COPY . .`, so anything not excluded here lands in
# the image — this file is the guard.

# --- Secrets: never bake into an image ---
.env
.env.*
!.env.example

# --- Virtual environments ---
.venv/
venv/
env/

# --- Python runtime junk ---
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Data and model artifacts ---
# CICIDS data never belongs in an image. All .pkl/.joblib are excluded by
# default, EXCEPT the two approved model artifacts, which ARE baked into
# the image so the deployed service can score (their hashes are verified
# at startup against model/model_card.json). Locally, docker-compose still
# overlays ./model as a read-only mount.
data/
*.pkl
*.joblib
!model/preprocessor.pkl
!model/isolation_forest.pkl

# --- Local databases ---
*.db
*.sqlite
*.sqlite3

# --- Tests: not needed to RUN the app (CI runs them separately) ---
tests/

# --- Git and CI metadata ---
.git/
.github/
.gitignore

# --- Editor / OS junk ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# --- Docs (the large project .docx especially) ---
docs/

# --- Throwaway diagnostics that live in project root ---
attack_type_recall.py
check_*.py
manual_check.py
body*.json

# --- Stray local temp files/dirs (can be unreadable to the build sender) ---
.test_tmp
*.tmp
tmp/